#include <iostream>
#include <iomanip>
#include <string>

using namespace std;

double computeWaterBill(double consumption, string type) {
    double rate = 0.0;

    // Define rates based on the type of user
    if (type == "residential") {
        if (consumption <= 10) {
            rate = 10.00; // Fixed rate for the first 10 cubic meters
        } else if (consumption <= 30) {
            rate = 15.00; // Rate for 11 to 30 cubic meters
        } else {
            rate = 20.00; // Rate for above 30 cubic meters
        }
    } else if (type == "commercial") {
        if (consumption <= 10) {
            rate = 20.00; // Fixed rate for the first 10 cubic meters
        } else if (consumption <= 30) {
            rate = 30.00; // Rate for 11 to 30 cubic meters
        } else {
            rate = 40.00; // Rate for above 30 cubic meters
        }
    } else {
        cout << "Invalid type!" << endl;
        return 0.0;
    }

    return consumption * rate; // Calculate total bill
}

int main() {
    double previousReading, presentReading, consumption;
    string type, tubeSize;
    // Ask for the tube size
    cout << "Enter the tube size (in inches): ";
    cin >> tubeSize;

    // Display the tube size
    cout << "You entered a tube size of: " << tubeSize << " inches." << endl;

    // Compute and display the water bill
    double bill = computeWaterBill(consumption, type);
    cout << fixed << setprecision(2);
    cout << "Your water consumption is: " << consumption << " cubic meters." << endl;
    cout << "Your total water bill is: Php " << bill << endl;

    return 0;
}